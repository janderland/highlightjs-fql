{
  "name": "highlightjs-fql",
  "version": "0.1.0",
  "description": "FQL (FoundationDB Query Language) syntax highlighting for highlight.js",
  "type": "module",
  "main": "src/fql.js",
  "exports": {
    ".": "./src/fql.js",
    "./register": "./src/register.js"
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "rollup -c",
    "test": "node test/run.js"
  },
