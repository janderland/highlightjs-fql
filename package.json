    "url": "git+https://github.com/janderland/highlightjs-fql.git"
  },
  "homepage": "https://github.com/janderland/fql",
  "license": "Apache-2.0",
  "peerDependencies": {
    "highlight.js": "^11.0.0"
  },
  "devDependencies": {
    "@rollup/plugin-terser": "^1.0.0",
    "highlight.js": "^11.9.0",
    "rollup": "^4.0.0"
  }
